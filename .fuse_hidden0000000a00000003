<style>
  :root{
    --gold:#AE841F; --navy:#02394F; --green:#224C37;
    --orange:#AF561B; --yellow:#F3C645;
    --navy-90:#083749; --ink:#0d2733; --paper:#f7f4ec; --line:rgba(255,255,255,.14);
    --font:"Raleway",system-ui,sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{font-family:var(--font);color:var(--ink);background:var(--paper);line-height:1.6;font-weight:400}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:1160px;margin:0 auto;padding:0 28px}
  h1,h2,h3{font-weight:900;line-height:1.08;letter-spacing:-.01em}
  .eyebrow{font-weight:700;letter-spacing:.18em;text-transform:uppercase;font-size:.72rem;color:var(--gold)}
  .btn{display:inline-block;font-weight:800;letter-spacing:.02em;padding:15px 30px;border-radius:4px;font-size:.95rem;transition:.15s;cursor:pointer;border:2px solid transparent}
  .btn-gold{background:var(--gold);color:#fff}
  .btn-gold:hover{background:#96711a}
  .btn-outline{border-color:var(--gold);color:var(--gold);background:transparent}
  .btn-outline:hover{background:var(--gold);color:#fff}
  .btn-ghost{border-color:rgba(255,255,255,.5);color:#fff}
  .btn-ghost:hover{background:#fff;color:var(--navy)}

  /* NAV */
  header{position:sticky;top:0;z-index:50;background:var(--navy);border-bottom:1px solid var(--line)}
  nav{display:flex;align-items:center;justify-content:space-between;height:76px}
  nav .logo img{height:44px;display:block}
  nav ul{display:flex;gap:26px;list-style:none;align-items:center}
  nav ul a{color:#e9eef1;font-weight:600;font-size:.9rem;letter-spacing:.01em}
  nav ul a:hover{color:var(--yellow)}
  nav .navcta{display:flex;gap:14px;align-items:center}
  .login{color:#aebfc7 !important;font-weight:600;font-size:.85rem}
  @media(max-width:1000px){nav ul{display:none}}

  /* HERO */
  .hero{background:var(--navy);color:#fff;padding:84px 0 96px;position:relative;overflow:hidden}
  .hero:after{content:"";position:absolute;right:-120px;top:-80px;width:520px;height:520px;border-radius:50%;background:radial-gradient(circle,rgba(174,132,31,.22),transparent 68%)}
  .hero .wrap{position:relative;z-index:2;max-width:820px}
  .hero h1{font-size:clamp(2.4rem,5vw,4rem);margin:18px 0 20px}
  .hero h1 em{font-style:normal;color:var(--yellow)}
  .hero .sub{font-size:1.28rem;font-weight:600;color:#dfe8ec;margin-bottom:14px}
  .hero p{font-size:1.05rem;color:#c3d0d6;max-width:640px;margin-bottom:32px}
  .hero .cta-row{display:flex;gap:16px;flex-wrap:wrap}
  .credline{margin-top:34px;font-size:.82rem;letter-spacing:.14em;text-transform:uppercase;color:#8fa6af;font-weight:600}

  /* STAT BAR */
  .stats{background:var(--ink);color:#fff}
  .stats .wrap{display:grid;grid-template-columns:repeat(4,1fr);gap:0}
  .stat{padding:30px 20px;text-align:center;border-right:1px solid var(--line)}
  .stat:last-child{border-right:none}
  .stat b{display:block;font-size:2.3rem;font-weight:900;color:var(--yellow);line-height:1}
  .stat span{font-size:.82rem;color:#b7c6cc;font-weight:600;letter-spacing:.04em}
  @media(max-width:720px){.stats .wrap{grid-template-columns:repeat(2,1fr)}.stat:nth-child(2){border-right:none}}

  /* SECTIONS */
  section{padding:80px 0}
  .section-head{max-width:680px;margin-bottom:48px}
  .section-head h2{font-size:clamp(1.9rem,3.4vw,2.7rem);color:var(--navy);margin:12px 0 14px}
  .section-head p{font-size:1.08rem;color:#4a5c63}

  /* BENEFITS */
  .benefits{background:#fff}
  .bgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
  .bcard{padding:34px 28px;border:1px solid #e6e0d2;border-radius:8px;background:var(--paper)}
  .bcard .ic{width:46px;height:46px;border-radius:8px;background:var(--navy);color:var(--yellow);display:grid;place-items:center;font-weight:900;font-size:1.3rem;margin-bottom:18px}
  .bcard h3{font-size:1.15rem;color:var(--navy);margin-bottom:10px}
  .bcard p{font-size:.96rem;color:#4a5c63}
  @media(max-width:820px){.bgrid{grid-template-columns:1fr}}

  /* COURSES */
  .courses{background:var(--paper)}
  .cgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
  .ccard{background:#fff;border-radius:10px;overflow:hidden;border:1px solid #e6e0d2;display:flex;flex-direction:column;box-shadow:0 2px 10px rgba(2,57,79,.05)}
  .ccard .top{padding:26px 26px 20px;color:#fff}
  .ccard.cbs .top{background:var(--green)}
  .ccard.cc .top{background:var(--navy)}
  .ccard.ac .top{background:var(--orange)}
  .ccard .top .tag{font-size:.72rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;opacity:.85}
  .ccard .top h3{font-size:1.5rem;margin:6px 0 4px}
  .ccard .top .price{font-weight:700;font-size:.95rem;opacity:.9}
  .ccard .body{padding:24px 26px;flex:1;display:flex;flex-direction:column}
  .ccard ul{list-style:none;margin-bottom:22px}
  .ccard li{padding:7px 0 7px 26px;position:relative;font-size:.94rem;color:#3c4c52;border-bottom:1px solid #f0ece1}
  .ccard li:before{content:"";position:absolute;left:0;top:14px;width:9px;height:9px;border-radius:50%;background:var(--gold)}
  .ccard .btn{margin-top:auto;text-align:center}
  @media(max-width:900px){.cgrid{grid-template-columns:1fr}}

  /* BIO */
  .bio{background:var(--navy);color:#fff}
  .bio .wrap{display:grid;grid-template-columns:0.9fr 1.1fr;gap:56px;align-items:center}
  .bio img{width:100%;border-radius:10px;border:3px solid var(--gold)}
  .bio h2{font-size:2.2rem;margin:12px 0 18px}
  .bio p{color:#cdd9de;font-size:1.05rem;margin-bottom:16px}
  .bio .creds{display:flex;flex-wrap:wrap;gap:10px;margin-top:22px}
  .bio .creds span{border:1px solid var(--line);border-radius:30px;padding:7px 16px;font-size:.82rem;font-weight:600;color:#e9eef1}
  @media(max-width:820px){.bio .wrap{grid-template-columns:1fr;gap:30px}}

  /* TESTIMONIALS */
  .tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  .tcard{background:#fff;border-radius:10px;padding:28px;border:1px solid #e6e0d2}
  .tcard .quote{font-size:1rem;color:#2f3e44;font-style:italic;margin-bottom:18px;line-height:1.55}
  .tcard .who{font-weight:800;color:var(--navy);font-size:.95rem}
  .tcard .role{font-size:.82rem;color:#7b8a90;font-weight:600}
  .tcard .stars{color:var(--gold);margin-bottom:14px;letter-spacing:2px}
  @media(max-width:900px){.tgrid{grid-template-columns:1fr}}

  /* BLOG */
  .blog{background:#fff}
  .blist{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  .bpost{border:1px solid #e6e0d2;border-radius:10px;overflow:hidden}
  .bpost .ph{height:150px;background:linear-gradient(135deg,var(--navy),var(--green))}
  .bpost .c{padding:22px}
  .bpost .date{font-size:.76rem;color:var(--gold);font-weight:700;letter-spacing:.08em;text-transform:uppercase}
  .bpost h3{font-size:1.08rem;color:var(--navy);margin:8px 0}
  @media(max-width:900px){.blist{grid-template-columns:1fr}}

  /* OPTIN */
  .optin{background:var(--yellow);color:var(--navy)}
  .optin .wrap{text-align:center;max-width:620px}
  .optin h2{font-size:2.2rem;margin-bottom:12px}
  .optin p{font-size:1.05rem;margin-bottom:26px;color:#3a3316}
  .optin form{display:flex;gap:10px;max-width:460px;margin:0 auto}
  .optin input{flex:1;padding:15px 18px;border-radius:5px;border:2px solid var(--navy);font-family:inherit;font-size:1rem}
  .optin .btn-navy{background:var(--navy);color:#fff;border:2px solid var(--navy)}

  /* FOOTER */
  footer{background:var(--ink);color:#b7c6cc;padding:56px 0 30px;font-size:.9rem}
  footer .cols{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:32px;margin-bottom:36px}
  footer img{height:40px;margin-bottom:16px}
  footer h4{color:#fff;font-size:.82rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:14px}
  footer ul{list-style:none}
  footer li{padding:5px 0}
  footer a:hover{color:var(--yellow)}
  footer .disc{border-top:1px solid var(--line);padding-top:22px;font-size:.78rem;color:#7f9199;line-height:1.6}
  @media(max-width:820px){footer .cols{grid-template-columns:1fr 1fr}}

  .badge{position:fixed;bottom:16px;left:16px;background:var(--navy);color:var(--yellow);font-weight:700;font-size:.72rem;padding:8px 14px;border-radius:30px;z-index:99;letter-spacing:.08em;box-shadow:0 4px 14px rgba(0,0,0,.25)}
</style>
</head>
