<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Beer Scholar — Direction B: The Closer</title>
<link rel="icon" href="assets/favicon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root{
    --gold:#AE841F; --navy:#02394F; --green:#224C37;
    --orange:#AF561B; --yellow:#F3C645; --ink:#12222a;
    --font:"Raleway",system-ui,sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{font-family:var(--font);color:var(--ink);background:#fff;line-height:1.6}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:1180px;margin:0 auto;padding:0 26px}
  h1,h2,h3{font-weight:900;line-height:1.05;letter-spacing:-.015em}
  .btn{display:inline-block;font-weight:800;padding:16px 34px;border-radius:50px;font-size:1rem;transition:.15s;cursor:pointer;border:none;text-align:center}
  .btn-yellow{background:var(--yellow);color:var(--navy);box-shadow:0 6px 0 #c99f27}
  .btn-yellow:hover{transform:translateY(2px);box-shadow:0 4px 0 #c99f27}
  .btn-orange{background:var(--orange);color:#fff;box-shadow:0 6px 0 #863f11}
  .btn-orange:hover{transform:translateY(2px);box-shadow:0 4px 0 #863f11}
  .btn-lg{padding:19px 44px;font-size:1.1rem}

  /* URGENCY BAR */
  .urgent{background:var(--orange);color:#fff;text-align:center;padding:10px;font-weight:700;font-size:.9rem;letter-spacing:.02em}
  .urgent b{color:var(--yellow)}

  /* NAV */
  header{position:sticky;top:0;z-index:50;background:#fff;box-shadow:0 2px 14px rgba(2,57,79,.08)}
  nav{display:flex;align-items:center;justify-content:space-between;height:72px}
  nav .logo img{height:42px;display:block}
  nav ul{display:flex;gap:24px;list-style:none;align-items:center}
  nav ul a{color:var(--navy);font-weight:700;font-size:.9rem}
  nav ul a:hover{color:var(--orange)}
  .navcta{display:flex;gap:14px;align-items:center}
  .login{color:#66787f !important;font-weight:700;font-size:.85rem}
  @media(max-width:1000px){nav ul{display:none}}

  /* HERO */
  .hero{background:linear-gradient(160deg,#fffdf5 0%,#fff6e0 100%);padding:66px 0 74px;position:relative;overflow:hidden}
  .hero .wrap{display:grid;grid-template-columns:1.15fr .85fr;gap:40px;align-items:center}
  .hero .pill{display:inline-block;background:var(--green);color:#fff;font-weight:800;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;padding:8px 16px;border-radius:30px;margin-bottom:20px}
  .hero h1{font-size:clamp(2.5rem,5.2vw,4.3rem);color:var(--navy);margin-bottom:20px}
  .hero h1 mark{background:var(--yellow);padding:0 8px;border-radius:4px}
  .hero .lead{font-size:1.2rem;font-weight:600;color:#3a4c53;margin-bottom:28px;max-width:520px}
  .hero .cta-row{display:flex;gap:16px;flex-wrap:wrap;align-items:center}
  .hero .micro{margin-top:18px;font-size:.9rem;color:#5a6c72;font-weight:600}
  .hero .micro b{color:var(--orange)}
  .herocard{background:var(--navy);border-radius:16px;padding:34px;color:#fff;box-shadow:0 20px 50px rgba(2,57,79,.28)}
  .herocard .big{font-size:4.2rem;font-weight:900;color:var(--yellow);line-height:1}
  .herocard .big span{font-size:1.6rem}
  .herocard h3{font-size:1.3rem;margin:6px 0 18px}
  .herocard ul{list-style:none}
  .herocard li{padding:9px 0 9px 30px;position:relative;font-size:.98rem;color:#d7e2e7;border-top:1px solid rgba(255,255,255,.12)}
  .herocard li:first-child{border-top:none}
  .herocard li:before{content:"✓";position:absolute;left:0;color:var(--yellow);font-weight:900}
  @media(max-width:900px){.hero .wrap{grid-template-columns:1fr}}

  /* LOGOS/TRUST STRIP */
  .trust{background:var(--navy);color:#fff;padding:26px 0}
  .trust .wrap{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:20px;text-align:center}
  .trust .t{flex:1;min-width:150px}
  .trust b{display:block;font-size:1.9rem;font-weight:900;color:var(--yellow);line-height:1}
  .trust span{font-size:.82rem;color:#b7c6cc;font-weight:600}

  section{padding:76px 0}
  .head{text-align:center;max-width:660px;margin:0 auto 50px}
  .head .kick{color:var(--orange);font-weight:800;letter-spacing:.12em;text-transform:uppercase;font-size:.78rem;margin-bottom:12px}
  .head h2{font-size:clamp(2rem,3.6vw,2.9rem);color:var(--navy);margin-bottom:14px}
  .head p{font-size:1.1rem;color:#4a5c63}

  /* PAIN/GAIN */
  .value{background:#fff}
  .vgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  .vcard{border-radius:14px;padding:32px 26px;background:#fdf9ee;border:2px solid #f2e9cf;text-align:center}
  .vcard .em{font-size:2.4rem;margin-bottom:14px}
  .vcard h3{color:var(--navy);font-size:1.2rem;margin-bottom:10px}
  .vcard p{font-size:.96rem;color:#4a5c63}
  @media(max-width:820px){.vgrid{grid-template-columns:1fr}}

  /* COURSES — pricing cards */
  .courses{background:linear-gradient(180deg,#fff6e0,#fffdf5)}
  .cgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;align-items:stretch}
  .pcard{background:#fff;border-radius:16px;padding:0;overflow:hidden;border:2px solid #eee2c4;display:flex;flex-direction:column;box-shadow:0 8px 24px rgba(2,57,79,.06)}
  .pcard.feat{border-color:var(--gold);transform:scale(1.03);box-shadow:0 16px 40px rgba(174,132,31,.22)}
  .pcard .ribbon{background:var(--gold);color:#fff;text-align:center;font-weight:800;font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;padding:8px}
  .pcard .inner{padding:30px 28px;display:flex;flex-direction:column;flex:1}
  .pcard .lvl{font-weight:800;color:var(--orange);font-size:.78rem;letter-spacing:.1em;text-transform:uppercase}
  .pcard h3{color:var(--navy);font-size:1.55rem;margin:6px 0 12px}
  .pcard .price{font-size:2.4rem;font-weight:900;color:var(--navy);line-height:1;margin-bottom:4px}
  .pcard .price small{font-size:.9rem;font-weight:600;color:#8a969b}
  .pcard .note{font-size:.86rem;color:#7c8990;margin-bottom:18px;font-weight:600}
  .pcard ul{list-style:none;margin-bottom:24px;flex:1}
  .pcard li{padding:8px 0 8px 26px;position:relative;font-size:.94rem;color:#3c4c52}
  .pcard li:before{content:"✓";position:absolute;left:0;color:var(--green);font-weight:900}
  @media(max-width:900px){.cgrid{grid-template-columns:1fr}.pcard.feat{transform:none}}

  /* BIG STAT / SOCIAL PROOF */
  .proof{background:var(--green);color:#fff;text-align:center}
  .proof h2{font-size:clamp(2rem,4vw,3rem);max-width:800px;margin:0 auto 16px}
  .proof h2 em{font-style:normal;color:var(--yellow)}
  .proof p{color:#cfe0d6;font-size:1.1rem;max-width:620px;margin:0 auto}

  /* TESTIMONIALS */
  .tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
  .tcard{background:#fff;border-radius:14px;padding:26px;border:2px solid #f0e9d6}
  .tcard .stars{color:var(--gold);letter-spacing:2px;margin-bottom:12px}
  .tcard .q{font-style:italic;color:#33434a;margin-bottom:16px;font-size:.98rem}
  .tcard .who{font-weight:800;color:var(--navy);font-size:.94rem}
  .tcard .role{font-size:.82rem;color:#7b8a90;font-weight:600}
  @media(max-width:900px){.tgrid{grid-template-columns:1fr}}

  /* FINAL CTA */
  .final{background:var(--navy);color:#fff;text-align:center}
  .final h2{font-size:clamp(2rem,4vw,3rem);margin-bottom:16px}
  .final h2 mark{background:var(--yellow);color:var(--navy);padding:0 8px;border-radius:4px}
  .final p{color:#c3d0d6;font-size:1.1rem;margin-bottom:28px}
  .final form{display:flex;gap:10px;max-width:500px;margin:0 auto}
  .final input{flex:1;padding:16px 20px;border-radius:50px;border:none;font-family:inherit;font-size:1rem}

  footer{background:#0c1a20;color:#a9bac1;padding:52px 0 28px;font-size:.9rem}
  footer .cols{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:30px;margin-bottom:34px}
  footer img{height:38px;margin-bottom:16px}
  footer h4{color:#fff;font-size:.8rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:14px}
  footer ul{list-style:none}footer li{padding:5px 0}
  footer a:hover{color:var(--yellow)}
  footer .disc{border-top:1px solid rgba(255,255,255,.12);padding-top:22px;font-size:.78rem;color:#7f9199;line-height:1.6}
  @media(max-width:820px){footer .cols{grid-template-columns:1fr 1fr}}

  .badge{position:fixed;bottom:16px;left:16px;background:var(--orange);color:#fff;font-weight:700;font-size:.72rem;padding:8px 14px;border-radius:30px;z-index:99;letter-spacing:.08em;box-shadow:0 4px 14px rgba(0,0,0,.25)}
</style>
</head>
