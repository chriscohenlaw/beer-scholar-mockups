<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Beer Scholar — Direction C: The Craft Guide</title>
<link rel="icon" href="assets/favicon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800;900&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,900&display=swap" rel="stylesheet">
<style>
  :root{
    --gold:#AE841F; --navy:#02394F; --green:#224C37;
    --orange:#AF561B; --yellow:#F3C645;
    --paper:#f4efe4; --paper2:#ece4d3; --ink:#2a2a24; --cream:#fbf8f1;
    --sans:"Raleway",system-ui,sans-serif;
    --serif:"Fraunces",Georgia,serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{font-family:var(--sans);color:var(--ink);background:var(--paper);line-height:1.7;font-weight:400}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:1120px;margin:0 auto;padding:0 30px}
  h1,h2,h3{font-family:var(--serif);font-weight:900;line-height:1.08;letter-spacing:-.01em}
  .btn{display:inline-block;font-family:var(--sans);font-weight:700;letter-spacing:.02em;padding:15px 32px;border-radius:2px;font-size:.95rem;transition:.2s;cursor:pointer;border:1.5px solid transparent}
  .btn-green{background:var(--green);color:var(--cream)}
  .btn-green:hover{background:#1a3a2a}
  .btn-gold{background:var(--gold);color:#fff}
  .btn-gold:hover{background:#95711b}
  .btn-line{border-color:var(--green);color:var(--green)}
  .btn-line:hover{background:var(--green);color:var(--cream)}
  .eyebrow{font-family:var(--sans);font-weight:700;letter-spacing:.22em;text-transform:uppercase;font-size:.7rem;color:var(--orange)}

  /* NAV */
  header{position:sticky;top:0;z-index:50;background:var(--paper);border-bottom:1px solid #d8cfba}
  nav{display:flex;align-items:center;justify-content:space-between;height:78px}
  nav .logo img{height:44px;display:block}
  nav ul{display:flex;gap:28px;list-style:none;align-items:center}
  nav ul a{color:var(--green);font-weight:600;font-size:.9rem}
  nav ul a:hover{color:var(--orange)}
  .navcta{display:flex;gap:16px;align-items:center}
  .login{color:#8a8064 !important;font-weight:600;font-size:.85rem}
  @media(max-width:1000px){nav ul{display:none}}

  /* HERO */
  .hero{padding:80px 0 20px;position:relative}
  .hero .wrap{max-width:940px;text-align:center}
  .hero h1{font-size:clamp(2.6rem,6vw,4.7rem);color:var(--green);margin:20px 0}
  .hero h1 em{font-style:italic;color:var(--gold)}
  .hero .lead{font-size:1.28rem;color:#54503f;max-width:660px;margin:0 auto 32px;font-weight:500}
  .hero .cta-row{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
  .rule{display:flex;align-items:center;justify-content:center;gap:16px;margin-top:44px;color:#8a8064;font-size:.8rem;letter-spacing:.15em;text-transform:uppercase;font-weight:600}
  .rule:before,.rule:after{content:"";height:1px;width:60px;background:#c9bfa6}

  /* HOP icon divider */
  .hopmark{text-align:center;font-size:1.4rem;color:var(--gold);margin:8px 0}

  /* FEATURE STRIP */
  .marquee{background:var(--green);color:var(--cream);padding:20px 0;margin-top:44px}
  .marquee .wrap{display:flex;justify-content:space-around;flex-wrap:wrap;gap:20px;text-align:center}
  .marquee .m b{font-family:var(--serif);font-size:1.7rem;color:var(--yellow);display:block;line-height:1}
  .marquee .m span{font-size:.8rem;color:#c7d6cd;letter-spacing:.06em}

  section{padding:82px 0}
  .head{max-width:640px;margin-bottom:48px}
  .head h2{font-size:clamp(2rem,3.6vw,2.9rem);color:var(--green);margin:14px 0}
  .head p{font-size:1.1rem;color:#54503f}
  .center{margin-left:auto;margin-right:auto;text-align:center}

  /* STORY / editorial split */
  .story{background:var(--cream)}
  .story .wrap{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
  .story .photo{position:relative}
  .story .photo img{width:100%;border-radius:4px;filter:saturate(1.05)}
  .story .photo .cap{position:absolute;bottom:-14px;left:-14px;background:var(--gold);color:#fff;padding:12px 20px;font-family:var(--serif);font-weight:600;font-size:.95rem;max-width:200px;line-height:1.3}
  .story h2{font-size:2.3rem;color:var(--green);margin:14px 0 20px}
  .story p{color:#4a4636;font-size:1.06rem;margin-bottom:16px}
  .story .sig{font-family:var(--serif);font-style:italic;font-size:1.2rem;color:var(--gold);margin-top:10px}
  @media(max-width:860px){.story .wrap{grid-template-columns:1fr;gap:40px}}

  /* APPROACH / benefits editorial rows */
  .approach .row{display:grid;grid-template-columns:80px 1fr;gap:28px;padding:34px 0;border-top:1px solid #d8cfba;align-items:start}
  .approach .row:last-child{border-bottom:1px solid #d8cfba}
  .approach .num{font-family:var(--serif);font-size:2.6rem;color:var(--gold);font-weight:900;line-height:1}
  .approach .row h3{font-size:1.5rem;color:var(--green);margin-bottom:8px}
  .approach .row p{color:#54503f;font-size:1.04rem;max-width:640px}
  @media(max-width:640px){.approach .row{grid-template-columns:1fr;gap:8px}}

  /* COURSES editorial cards */
  .courses{background:var(--paper2)}
  .cgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
  .ccard{background:var(--cream);border-radius:4px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 3px 16px rgba(42,42,36,.07)}
  .ccard .band{height:6px}
  .ccard.cbs .band{background:var(--gold)}
  .ccard.cc .band{background:var(--green)}
  .ccard.ac .band{background:var(--orange)}
  .ccard .in{padding:30px 28px;display:flex;flex-direction:column;flex:1}
  .ccard .lvl{font-family:var(--sans);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.72rem;color:var(--orange)}
  .ccard h3{font-size:1.6rem;color:var(--green);margin:8px 0}
  .ccard .desc{font-size:.98rem;color:#54503f;margin-bottom:18px}
  .ccard ul{list-style:none;margin-bottom:24px}
  .ccard li{padding:6px 0 6px 22px;position:relative;font-size:.92rem;color:#4a4636}
  .ccard li:before{content:"❋";position:absolute;left:0;color:var(--gold);font-size:.8rem;top:8px}
  .ccard .btn{margin-top:auto;text-align:center}
  @media(max-width:860px){.cgrid{grid-template-columns:1fr}}

  /* PULL QUOTE */
  .pull{background:var(--green);color:var(--cream);text-align:center}
  .pull .wrap{max-width:820px}
  .pull blockquote{font-family:var(--serif);font-size:clamp(1.6rem,3.4vw,2.4rem);line-height:1.3;font-weight:600;margin-bottom:20px}
  .pull blockquote em{color:var(--yellow);font-style:italic}
  .pull .attr{font-family:var(--sans);font-size:.85rem;letter-spacing:.1em;text-transform:uppercase;color:#b6c8be}

  /* TESTIMONIALS */
  .tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
  .tcard{background:var(--cream);border-radius:4px;padding:30px;border-left:3px solid var(--gold)}
  .tcard .q{font-family:var(--serif);font-size:1.05rem;color:#3a382c;line-height:1.5;margin-bottom:18px}
  .tcard .who{font-weight:700;color:var(--green);font-size:.94rem}
  .tcard .role{font-size:.82rem;color:#8a8064;font-weight:600}
  @media(max-width:860px){.tgrid{grid-template-columns:1fr}}

  /* BLOG */
  .blog{background:var(--cream)}
  .blist{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
  .bpost .ph{height:160px;border-radius:4px;background:linear-gradient(135deg,var(--green),var(--gold))}
  .bpost .date{font-family:var(--sans);font-size:.74rem;color:var(--orange);font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-top:16px}
  .bpost h3{font-size:1.15rem;color:var(--green);margin-top:8px}
  @media(max-width:860px){.blist{grid-template-columns:1fr}}

  /* OPTIN */
  .optin{background:var(--gold)}
  .optin .wrap{text-align:center;max-width:620px}
  .optin h2{color:#3a2c05;font-size:2.2rem;margin-bottom:12px}
  .optin p{color:#4a3a10;font-size:1.06rem;margin-bottom:26px}
  .optin form{display:flex;gap:10px;max-width:460px;margin:0 auto}
  .optin input{flex:1;padding:15px 18px;border-radius:2px;border:1.5px solid var(--green);font-family:inherit;font-size:1rem;background:var(--cream)}

  footer{background:var(--green);color:#c7d6cd;padding:58px 0 30px;font-size:.9rem}
  footer .cols{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:32px;margin-bottom:36px}
  footer img{height:40px;margin-bottom:16px}
  footer h4{font-family:var(--sans);color:var(--cream);font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:14px}
  footer ul{list-style:none}footer li{padding:5px 0}
  footer a:hover{color:var(--yellow)}
  footer .disc{border-top:1px solid rgba(255,255,255,.14);padding-top:22px;font-size:.78rem;color:#9db3a8;line-height:1.6}
  @media(max-width:820px){footer .cols{grid-template-columns:1fr 1fr}}

  .badge{position:fixed;bottom:16px;left:16px;background:var(--green);color:var(--yellow);font-weight:700;font-size:.72rem;padding:8px 14px;border-radius:30px;z-index:99;letter-spacing:.08em;box-shadow:0 4px 14px rgba(0,0,0,.25)}
</style>
</head>
